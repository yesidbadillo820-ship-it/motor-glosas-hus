# ============================================================
#  Motor Glosas HUS — Variables de entorno requeridas
#  Copiar este archivo como .env y completar los valores reales
# ============================================================

# ----- Base de datos ----------------------------------------
# SQLite local (desarrollo):
DATABASE_URL=sqlite:///./glosas.db

# PostgreSQL producción (Render, Supabase, etc.):
# DATABASE_URL=postgresql://usuario:contraseña@host:5432/glosas_hus

# ----- Seguridad JWT (OBLIGATORIO) --------------------------
# Generar con: openssl rand -hex 32
SECRET_KEY=CAMBIAR_POR_UNA_CLAVE_LARGA_Y_ALEATORIA_MINIMO_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ----- Contraseña del admin inicial (OBLIGATORIO) -----------
ADMIN_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# ----- Llaves de IA (al menos una requerida) ----------------
GROQ_API_KEY=gsk_...
ANTHROPIC_API_KEY=sk-ant-...

# ----- CORS: dominios permitidos (producción) ---------------
# Separar por comas, sin espacios
ALLOWED_ORIGINS=https://hus.gov.co,https://motor-glosas.hus.gov.co

# ----- Configuración de correo para alertas -----------------
# SMTP para envío de alertas (Gmail, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alertas@hus.gov.co
SMTP_PASSWORD=contraseña_app_gmail_16_caracteres
SMTP_FROM=noreply@hus.gov.co

# Destinatarios de alertas (separados por coma)
# ALERTAS_EMAIL=cartera@hus.gov.co,auditoria@hus.gov.co,director@hus.gov.co

# ----- Metadatos de la app ----------------------------------
APP_NAME=Motor Glosas HUS
APP_VERSION=5.2.0
